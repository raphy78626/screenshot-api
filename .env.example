# Port to listen on (Fly uses 8080 via fly.toml [env])
PORT=3099

# Host to bind to (0.0.0.0 for Fly/Docker, 127.0.0.1 for local-only)
HOST=0.0.0.0

# Navigation timeout in milliseconds before returning a 504
NAV_TIMEOUT_MS=20000

# Max simultaneous Playwright browser contexts (each costs ~50-150MB)
# 1GB VM: use 2. 512MB VM: use 1.
MAX_CONCURRENCY=2

# Per-IP rate limit (requests per minute)
RATE_LIMIT_MAX=60

# Shared secret for the X-RapidAPI-Proxy-Secret / X-Proxy-Secret header.
# Required in production to prevent callers from bypassing RapidAPI billing.
# Empty = auth disabled (local dev default).
# Generate: openssl rand -hex 24
PROXY_SECRET=

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Whether Fastify should trust X-Forwarded-For (set false only if not behind a proxy)
TRUST_PROXY=true
